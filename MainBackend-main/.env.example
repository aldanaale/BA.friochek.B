# Archivo de Configuración de Ambiente
# Copiar a .env y completar con valores reales
# NO VERSIONAR EN GIT (agregado a .gitignore)

# ============================================
# SQL Server Connection
# ============================================
SQLSERVER_CONNECTION_STRING=Server=localhost;Database=BA_Backend_DB;User Id=sa;Password=YourPassword123!;TrustServerCertificate=True;

# Alternativa para Docker SQL Server
# SQLSERVER_CONNECTION_STRING=Server=sqlserver;Database=BA_Backend_DB;User Id=sa;Password=YourPassword123!;TrustServerCertificate=True;

# ============================================
# JWT Configuration
# ============================================
# Mínimo 32 caracteres para seguridad
# Generar con: [Convert]::ToBase64String((1..32 | ForEach-Object { [byte](Get-Random -Maximum 256) }))
JWT_SECRET_KEY=your-super-secret-key-min-32-characters-long-for-security-change-this

JWT_ISSUER=BA.Backend
JWT_AUDIENCE=BA.Backend.Users
JWT_EXPIRATION_MINUTES=60

# ============================================
# Environment
# ============================================
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=https://localhost:5001;http://localhost:5000

# ============================================
# Logging
# ============================================
LOG_LEVEL=Information

# ============================================
# CORS Settings
# ============================================
CORS_ALLOWED_ORIGINS=https://localhost:3000,http://localhost:3000

# ============================================
# Security
# ============================================
ENABLE_HTTPS=true
REQUIRE_HTTPS_REDIRECT=true

# ============================================
# Analytics (Futuro)
# ============================================
# ANALYTICS_CONNECTION_STRING=
# ANALYTICS_API_KEY=
